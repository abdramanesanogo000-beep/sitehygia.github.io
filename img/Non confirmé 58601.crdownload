presisted) {          layout()        }      })    })(window, document)  </script><div id="pc"><div class="flex-item-content"><div style="margin-top: 11px; text-align: center;"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://www.jinlantrade.com/ebay/VEVOR/vevor-2.png?x-oss-process=image/format,webp" class="flex-item-content-item-describe"></div><div class="flex-item-txt" style="margin-top: 24px;"><div class="flex-item-txt-title-describete">Tough Equipment & Tools, Pay Less</div><div class="flex-item-txt-describe">VEVOR est le plus grand fournisseur spécialisé en équipements et outillages. Avec des milliers d'employés motivés, VEVOR s'engage à fournir à ses clients des équipements et des outils solides à des prix extrêmement bas. Aujourd'hui, les produits de VEVOR sont vendus dans plus de 200 pays et régions, avec plus de 10 millions de membres dans le monde.</div></div><div class="pcdescribe-title">Pourquoi Choisir VEVOR?</div><div class="pcdescribe-uls"><ul class="pcdescribe-uls-li"><li class="pcdescribe-uls-lis"><span class="pcdescribe-uls-lis-circle"></span>Qualité Garantie</li><li class="pcdescribe-uls-lis"><span class="pcdescribe-uls-lis-circle"></span>Prix Extrêmement Bas</li><li class="pcdescribe-uls-lis"><span class="pcdescribe-uls-lis-circle"></span>Livraison Rapide & Sûre</li><li class="pcdescribe-uls-lis"><span class="pcdescribe-uls-lis-circle"></span>30 Jours Retours Gratuits</li><li class="pcdescribe-uls-lis"><span class="pcdescribe-uls-lis-circle"></span>24/7 Service Attentif</li></ul></div></div></div><div id="h5"><div class="description2"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/prm/vevor-2-M.png?x-oss-process=image/format,webp" class="description-img2" alt="Logo VEVOR"></div><div class="description-title2">Tough Equipment & Tools, Pay Less</div><div class="description-txt">VEVOR est le plus grand fournisseur spécialisé en équipements et outillages. Avec des milliers d'employés motivés, VEVOR s'engage à fournir à ses clients des équipements et des outils solides à des prix extrêmement bas. Aujourd'hui, les produits de VEVOR sont vendus dans plus de 200 pays et régions, avec plus de 10 millions de membres dans le monde.</div><div class="description-title">Pourquoi Choisir VEVOR?</div><div class="describe-uls"><ul class="describe-uls-li"><li class="describe-uls-lis"><span class="describe-uls-circle"></span> Qualité Garantie</li><li class="describe-uls-lis"><span class="describe-uls-circle"></span> Prix Extrêmement Bas</li><li class="describe-uls-lis"><span class="describe-uls-circle"></span> Livraison Rapide & Sûre</li><li class="describe-uls-lis"><span class="describe-uls-circle"></span> 30 Jours Retours Gratuits</li><li class="describe-uls-lis"><span class="describe-uls-circle"></span> 24/7 Service Attentif</li></ul></div></div><div><style>  @media screen and (max-width: 750px) {    #h5 {      display: block;      overflow-x: hidden;      font-family: Roboto, Open Sans, Helvetica, Arial, sans-serif;    }    #pc {      display: none;    }  }  @media (min-width: 750px) {    #h5 {      display: none;    }    #pc {      display: block;      font-family: Open sans, Arial, Helvetica, sans-serif;    }  }  .flex-item-content {    margin-left: 16px;  }  .flex-item-content-item-describe {    width: 100%;    height: auto;  }  .flex-item-txt {    margin-top: 14px;  }  .pcdescribe-uls {    background: #f3f3f3;    border-radius: 8px;    padding: 18px 22px;    margin-top: 11px;    border: 1px solid #ddd;  }  .pcdescribe-uls-li {    list-style: none !important;    margin: 0 !important;    padding: 0 !important;  }  .pcdescribe-uls-lis {    color: #000;    font-size: 14px;    list-style: none;    text-align: left;  }  .pcdescribe-uls-lis-circle {    display: inline-block;    background: #000;    border-radius: 50%;    margin-right: 8px;    width: 6px;    height: 6px;    vertical-align: middle;  }  .flex-item-txt-title-describete {    color: #000;    font-size: 14px;    font-weight: bold;  }  .pcdescribe-title{    font-size: 14px;    color: #000;    font-weight: bold;    margin-top: 14px;  }  .description2 {    text-align: center;    margin-top: 1.33rem;    padding: 0 0.15rem;  }  .description-img2 {    height: auto;    width: 100%;  }  .description-title2 {    color: #000;    font-size: 0.26rem;    font-weight: bold;    margin-top: 1.17rem;    text-align: center;  }  .description-title {    color: #000;    font-size: 0.26rem;    font-weight: bold;    margin-top: 0.3rem;  }  .description-txt {    margin-top: 0.16rem;    color: #000;    font-size: 0.24rem;  }  .describe-uls {    margin-top: 0.26rem;    background: #f0f2f2;    padding: 0.14rem 0.16rem;    border-radius: 0.06rem;  }  .describe-uls-li {    list-style: none;    padding: 0 !important;    margin: 0 !important;  }  .describe-uls-lis {    position: relative;    list-style: none;    font-size: 0.24rem;    color: #000;    line-height: 1.5;  }  .describe-uls-circle {    width: 0.08rem;    height: 0.08rem;    border-radius: 50%;    background: #000;    display: inline-block;    vertical-align: middle;    margin-right: 0.07rem;  }</style></div></div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-1.2.jpg?x-oss-process=image/format,webp" class="imgs"></div><div><div class="description-title">Agitateur de Laboratoire Orbital Rotatif</div></div><div class="texts">Cet agitateur de laboratoire est fabriqué en matière plastique ABS robuste, avec une plate-forme de travail antidérapante et une base stable. Avec la vitesse réglable de 0 - 210 tr / min et une minuterie précise pour un travail continu ou un chronométrage de 1 - 15 min, l’agitateur orbital et rotatif est facile à utiliser. Notre agitateur rotatif fonctionne en douceur, sans vibration et sans bruit, largement appliqué dans les instituts de recherche et les stations de prévention des infections.</div><div class="description-uls"><ul class="uls-detail"><li class="lis"><span class="description-circle"></span><span>Qualité Supérieure</span></li><li class="lis"><span class="description-circle"></span><span>Vitesse & Temps Réglables</span></li><li class="lis"><span class="description-circle"></span><span>Fonctionnement Silencieux & Stable</span></li><li class="lis"><span class="description-circle"></span><span>Grande Plateforme</span></li></ul></div><div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-2.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Matériau Robuste</div><div class="texts">Construit avec une matière plastique ABS de haute qualité, la machine d'agitation de laboratoire a une résistance et une ténacité élevées, ce qui la rend robuste et durable.</div></div><div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-3.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Vitesse Variable & Minuterie Précise</div><div class="texts">L'agitateur de laboratoire a une vitesse variable de 0 - 210 tr / min et une minuterie mécanique de 0 - 15 min pour le chronométrage ou le fonctionnement continu.</div></div><div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-4.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Pas de Vibration ni de Bruit</div><div class="texts">L'oscillateur ou le secoueur orbital fonctionne en douceur sans aucune vibration ni bruit. Il est facile à utiliser et fiable dans ses performances.</div></div><div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-5.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Plateforme de Travail Antidérapante</div><div class="texts">L’agitateur de laboratoire a une plate-forme de travail de 315 x 218 mm / 12,4 x 8,58 po, recouverte d'un coussin en caoutchouc souple pour empêcher le conteneur de glisser.</div></div><div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-6.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Base Stable avec Rangement</div><div class="texts">La base est conçue pour assurer la stabilité de l'agitateur rotatif de laboratoire pendant le fonctionnement, avec un réservoir de stockage caché sur le fond pour les accessoires.</div></div><div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-m100-7.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Utilisation Intensive</div><div class="texts">Notre agitateur de laboratoire est largement utilisé dans les établissements d'enseignement, les centres de prévention des maladies sexuelles et les stations de collecte de sang.</div></div><div class="tops"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-a100-3.jpg?x-oss-process=image/format,webp" class="imgs3"></div><div class="description-title-center">Contenu du coffret</div><div class="description-uls"><ul class="uls-detail"><li class="lis"><span class="description-circle"></span><span>1 x Agitateur orbital</span></li><li class="lis"><span class="description-circle"></span><span>1 x Manuel en anglais</span></li></ul></div><div class="tops padding"><img class="js-descLazyload " src="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs="  data-lazy="https://vevor-goods.vevor.net/product/SPXZY000000000001/orbital-shaker-a100-2.jpg?x-oss-process=image/format,webp" class="imgs"></div><div class="description-title">Spécification</div><ul class="uls-top"><li class="lis"><span class="description-circle"></span><span>Matériel : Plastique ABS</span></li><li class="lis"><span class="description-circle"></span><span>Alimentation : AC 110 / 220 V 20 / 60 Hz</span></li><li class="lis"><span class="description-circle"></span><span>Vitesse : 0 - 210 tr / min</span></li><li class="lis"><span class="description-circle"></span><span>Minuterie : 0 - 15 min</span></li><li class="lis"><span class="description-circle"></span><span>Diamètre de l'orbite : 22 mm / 0,87 po</span></li><li class="lis"><span class="description-circle"></span><span>Mode de travail : Chronométrage / continu</span></li><li class="lis"><span class="description-circle"></span><span>Fusible : 1 A</span></li><li class="lis"><span class="description-circle"></span><span>Taille de la plate-forme (L * Largeur) : 315 x 218 mm / 12,4 x 8,58 po</span></li><li class="lis"><span class="description-circle"></span><span>Taille de la machine (L * Largeur * H) : 320 x 320 x 130 mm / 12,6 x 12,6 x 5,1 po</span></li><li class="lis"><span class="description-circle"></span><span>Poids de la machine : 3,3 kg / 7,28 lb</span></li></ul></div><div><style scoped>      @media screen and (min-width: 990px) and (max-width: 1200px) {        .content {          display: none;       